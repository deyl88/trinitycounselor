# ─────────────────────────────────────────────
# Trinity Counselor — Environment Configuration
# Copy this file to .env and fill in all values.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-in-production

# ── PostgreSQL + pgvector ─────────────────────
# asyncpg connection string (used by SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://trinity:trinity@localhost:5432/trinity
# psycopg3 connection string (used by LangGraph checkpointer + PGVector)
POSTGRES_URL=postgresql://trinity:trinity@localhost:5432/trinity

# ── Neo4j ────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── Anthropic ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── OpenAI (embeddings only) ─────────────────
# Used for pgvector semantic memory (text-embedding-3-small).
# Swap for VoyageAI or any LangChain-compatible embeddings provider.
OPENAI_API_KEY=sk-...

# ── JWT ──────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440   # 24 hours

# ── Encryption ───────────────────────────────
# 32-byte master key, base64-encoded.
# Generate with: python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
MASTER_KEY=base64-encoded-32-byte-key-here
