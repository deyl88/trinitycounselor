# ─── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── PostgreSQL + pgvector ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://trinity:trinity@localhost:5432/trinity
# Sync URL used by Alembic only
DATABASE_SYNC_URL=postgresql+psycopg://trinity:trinity@localhost:5432/trinity

# ─── Neo4j (RKG) ──────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth ─────────────────────────────────────────────────────────────────────
# 32-byte secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=changeme-generate-a-real-secret-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Encryption ───────────────────────────────────────────────────────────────
# Master key for envelope encryption of per-user DEKs
# 32-byte hex — generate with: python -c "import secrets; print(secrets.token_hex(32))"
MASTER_ENCRYPTION_KEY=changeme-generate-a-real-key-here

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development        # development | staging | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# ─── Safety ───────────────────────────────────────────────────────────────────
# Intensity threshold (0.0–1.0) above which crisis_check fires LLM classifier
CRISIS_INTENSITY_THRESHOLD=0.7
